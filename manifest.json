{
  "manifest_version": 3,
  "name": "IBKR Tax Year Filler",
  "description": "Sets IBKR report dates to the previous tax year.",
  "version": "1.1",
  "permissions": [
    "scripting",
    "activeTab",
    "declarativeContent"
  ],
  "host_permissions": [
    "https://*.interactivebrokers.com/*",
    "https://*.interactivebrokers.co.uk/*",
    "https://*.interactivebrokers.ie/*"
  ],
  "action": {
    "default_title": "Set to Previous Tax Year"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png"
  }
}